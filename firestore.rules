rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - allow auth users to read their own doc, admin can manage all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          canSelfPromoteToAdmin()
        )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // Materials collection - allow all authenticated users to read, only admin/dosen to write
    match /materials/{materialId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isTeacher();
      allow update: if request.auth != null && (hasRole('admin') || isAuthor());
      allow delete: if request.auth != null && hasRole('admin');
    }

    // Quiz questions - allow authenticated users to read questions, only teachers can add
    match /quizQuestions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isTeacher();
      allow update: if request.auth != null && isTeacher();
      allow delete: if request.auth != null && isAdmin();
    }

    // Quiz results - allow students to submit their own results; teachers/admin can read
    match /quizResults/{resultId} {
      allow read: if request.auth != null && (isTeacher() || request.auth.uid == resource.data.userUid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userUid;
      allow update: if false;
      allow delete: if request.auth != null && isAdmin();
    }

    // Attendance sessions - teachers can create, all authenticated users can read
    match /attendance_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isTeacher();
      allow update: if request.auth != null && isTeacher();
      allow delete: if request.auth != null && isAdmin();
    }

    // Attendances - students can create their own attendance, teachers can manage reconciliation
    match /attendances/{attendanceId} {
      allow read: if request.auth != null && (
        isTeacher() ||
        request.auth.uid == resource.data.user_id
      );
      allow create: if request.auth != null && (
        isTeacher() ||
        request.auth.uid == request.resource.data.user_id
      );
      allow update: if false;
      allow delete: if request.auth != null && isAdmin();
    }

    // Admin emails whitelist - admin role check during login
    match /adminEmails/{email} {
      allow read: if request.auth != null;
      allow write: if false; // Ditulis hanya dari backend service account
    }

    // Helper functions
    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) {
        return false;
      }
      let userDoc = get(userPath);
      return userDoc.data.role == 'admin';
    }

    function isTeacher() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) {
        return false;
      }
      let userDoc = get(userPath);
      return userDoc.data.role == 'admin' || userDoc.data.role == 'dosen';
    }

    function isAuthor() {
      let docData = resource.data;
      return docData.authorUid == request.auth.uid;
    }

    function hasRole(role) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) {
        return false;
      }
      let userDoc = get(userPath);
      return userDoc.data.role == role;
    }

    function canSelfPromoteToAdmin() {
      if (!(request.auth.token.email is string)) {
        return false;
      }
      let normalizedEmail = request.auth.token.email.lower();
      let adminDoc = get(/databases/$(database)/documents/adminEmails/$(normalizedEmail));

      return adminDoc.data.isAdmin == true &&
        request.resource.data.role == 'admin' &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt;
    }
  }
}
